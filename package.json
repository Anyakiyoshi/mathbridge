{
  "name": "mathbridge",
  "private": true,
  "version": "1.0.0",
  "description": "MathBridge — 高数全流程交互式带学平台",
  "author": "杨子墨",
  "main": "electron/main.cjs",
  "type": "module",
  "scripts": {
    "dev": "vite",
    "dev:desktop": "concurrently \"vite\" \"wait-on http://localhost:5173 && electron .\"",
    "build": "vite build",
    "build:desktop": "vite build --base=./ && electron-builder --win dir",
    "build:pages": "vite build --base=/mathbridge/",
    "lint": "oxlint",
    "preview": "vite preview",
    "deploy": "npm run build:pages && gh-pages -d dist",
    "start": "npx serve dist -l 3000"
  },
  "build": {
    "appId": "com.mathbridge.app",
    "productName": "MathBridge",
    "directories": {
      "output": "release"
    },
    "files": [
      "dist/**/*",
      "electron/**/*",
      "public/**/*"
    ],
    "win": {
      "target": ["dir"]
    }
  },
  "dependencies": {
    "@react-three/drei": "^10.7.7",
    "@react-three/fiber": "^9.6.1",
    "@types/three": "^0.185.0",
    "d3": "^7.9.0",
    "katex": "^0.17.0",
    "react": "^19.2.7",
    "react-dom": "^19.2.7",
    "three": "^0.185.1",
    "zustand": "^5.0.14"
  },
  "devDependencies": {
    "@types/node": "^24.13.2",
    "@types/react": "^19.2.17",
    "@types/react-dom": "^19.2.3",
    "@vitejs/plugin-react": "^6.0.3",
    "concurrently": "^10.0.3",
    "electron": "^43.1.0",
    "electron-builder": "^26.15.3",
    "gh-pages": "^6.3.0",
    "oxlint": "^1.71.0",
    "typescript": "~6.0.2",
    "vite": "^8.1.1"
  }
}
